generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  conversations  Conversation[]
  searches       Search[]
  affiliateClicks AffiliateClick[]
  favorites      Favorite[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("Nueva conversación")
  userId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Hotel {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  city          String
  country       String
  zone          String
  pricePerNight Float
  currency      String   @default("EUR")
  rating        Float
  description   String   @db.Text
  highlights    String[]
  imageUrl      String
  bookingUrl    String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  favorites Favorite[]

  @@index([city, isActive])
  @@index([pricePerNight])
  @@map("hotels")
}

model Search {
  id        String   @id @default(cuid())
  userId    String?
  query     String
  city      String?
  country   String?
  budget    String?
  maxPrice  Float?
  style     String?
  results   Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("searches")
}

model AffiliateClick {
  id        String   @id @default(cuid())
  userId    String?
  hotelName String
  city      String
  url       String
  referrer  String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([hotelName])
  @@map("affiliate_clicks")
}

model SEOPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  metaDescription String
  h1              String
  content         String   @db.Text
  city            String
  country         String
  keywords        String[]
  faqs            Json?
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([city])
  @@map("seo_pages")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  hotelId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([userId, hotelId])
  @@map("favorites")
}

enum UserRole {
  USER
  ADMIN
}
