# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/takeitrip"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Booking.com Affiliate
BOOKING_AFFILIATE_ID=your-affiliate-id
BOOKING_CAMPAIGN_ID=your-campaign-id

# Booking.com Demand API (affiliate partners)
BOOKING_API_KEY=your-booking-api-key
BOOKING_API_URL=https://demandapi-sandbox.booking.com/3.1

# Civitatis API (tours & activities)
CIVITATIS_API_KEY=your-civitatis-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AI Travel Assistant"
